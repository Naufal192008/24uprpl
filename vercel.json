# Buat file vercel.json untuk konfigurasi
@"
{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
"@ | Out-File -FilePath vercel.json -Encoding utf8

# Tambahkan ke git
git add vercel.json